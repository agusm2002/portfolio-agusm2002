---
const year = new Date().getFullYear();
---

<section id="contact" class="section">
  <div class="container">
    <div class="contact__card reveal">
      <!-- Glow -->
      <div class="contact__glow" aria-hidden="true"></div>

      <p class="section-label" style="justify-content:center">Contacto</p>
      <h2 class="contact__title">¿Hablamos?</h2>
      <p class="contact__desc">
        Estoy abierto a oportunidades, colaboraciones o simplemente
        charlar sobre infraestructura y tecnología.
        No dudes en escribirme.
      </p>

      <div class="contact__links">
        <a
          href="/CV_Agustin_Monti.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="btn contact__btn-neutral"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 3v12"/>
            <path d="m7 10 5 5 5-5"/>
            <path d="M5 21h14"/>
          </svg>
          Ver mi CV
        </a>
        <a
          href="https://github.com/agusm2002"
          target="_blank"
          rel="noopener noreferrer"
          class="btn contact__btn-neutral"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/agustin-monti-a23513253/?skipRedirect=true"
          target="_blank"
          rel="noopener noreferrer"
          class="btn contact__btn-neutral"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a
          href="mailto:agustinmonti2002@gmail.com"
          class="btn contact__btn-neutral"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <path d="m3 7 9 6 9-6"/>
          </svg>
          agustinmonti2002@gmail.com
        </a>
      </div>

      <p class="contact__mail-note">También podés escribirme directo por correo.</p>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer__inner">
    <span class="footer__logo">
      <span class="footer__dim">&lt;</span>agusm<span class="footer__green">2002</span><span class="footer__dim"> /&gt;</span>
    </span>
    <span class="footer__copy">
      Diseñado y construido por Agustín Monti · {year}
    </span>
    <span class="footer__stack">Astro · Lenis · GSAP</span>
  </div>
</footer>

<style>
  /* ── Contact ── */
  .contact__card {
    position: relative; overflow: hidden;
    max-width: 640px; margin-inline: auto;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 1.25rem; padding: 3.5rem 2.5rem;
    text-align: center;
    transition: border-color 0.25s;
  }

  .contact__card:hover { border-color: var(--border-hover); }

  .contact__glow {
    position: absolute; inset: -60px; z-index: 0;
    background: radial-gradient(circle at 50% 50%, rgba(34, 197, 94, 0.08), transparent 65%);
    pointer-events: none;
  }

  .contact__card > :not(.contact__glow) { position: relative; z-index: 1; }

  .contact__title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700; color: var(--green-50);
    letter-spacing: -0.03em; margin-bottom: 1rem;
  }

  .contact__desc {
    color: var(--text-muted); font-size: 1rem;
    line-height: 1.75; max-width: 42ch;
    margin-inline: auto; margin-bottom: 2.5rem;
  }

  .contact__links {
    display: flex; gap: 1rem;
    justify-content: center; flex-wrap: wrap;
  }

  .contact__links .btn {
    justify-content: center;
    min-width: 11.25rem;
  }

  .contact__btn-neutral {
    background: rgba(8, 15, 10, 0.55);
    color: var(--text-muted);
    border-color: var(--border);
  }

  .contact__btn-neutral:hover {
    background: rgba(26, 38, 30, 0.7);
    color: var(--text);
    border-color: var(--border-hover);
    box-shadow: none;
    transform: translateY(-1px);
  }

  .contact__mail-note {
    margin-top: 1rem;
    font-size: 0.82rem;
    color: var(--text-dim);
  }

  /* ── Footer ── */
  .footer {
    position: relative; z-index: 1;
    border-top: 1px solid var(--border);
    padding-block: 1.5rem;
  }

  .footer__inner {
    display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: 0.75rem;
  }

  .footer__logo {
    font-family: var(--font-mono); font-size: 0.875rem; color: var(--text);
  }

  .footer__dim   { color: var(--text-dim); }
  .footer__green { color: var(--green-500); }

  .footer__copy  { font-size: 0.8rem; color: var(--text-dim); }
  .footer__stack { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-dim); }

  @media (max-width: 600px) {
    .footer__inner { justify-content: center; text-align: center; }
    .contact__card { padding: 2.5rem 1.5rem; }
  }
</style>
