---
---

<section id="hero" class="hero">
  <div class="container hero__inner">

    <!-- Left: copy -->
    <div class="hero__text">
      <div class="hero__badge" data-hero="badge">
        <span class="hero__pulse"></span>
        Abierto a oportunidades
      </div>

      <h1 class="hero__name" data-hero="name">
        Agustín<br /><span class="hero__name-green">Monti</span>
      </h1>

      <p class="hero__role" data-hero="role">
        <span class="hero__comment">// </span><span id="typewriter" aria-live="polite"></span><span class="hero__cursor">|</span>
      </p>

      <p class="hero__desc" data-hero="desc">

  Estudiante de Ingeniería en Informática apasionado por

  <span class="hl">Linux</span>, <span class="hl">infraestructura</span> y

  <span class="hl">automatización</span>. Construyendo mi camino hacia

  <span class="hl">DevOps</span>, con foco en la

  <span class="hl">mejora continua del software</span>.

</p>


      <div class="hero__ctas" data-hero="ctas">
        <a href="#projects" class="btn btn-primary">
          Ver proyectos
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/CV_Agustin_Monti.pdf" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 3v12"/>
            <path d="m7 10 5 5 5-5"/>
            <path d="M5 21h14"/>
          </svg>
          Ver mi CV
        </a>
        <a href="https://github.com/agusm2002" target="_blank" rel="noopener noreferrer" class="btn btn-outline">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>

    <!-- Right: terminal -->
    <div class="hero__terminal-wrap" data-hero="terminal">
      <div class="terminal" role="presentation">
        <div class="terminal__bar">
          <div class="terminal__dots">
            <span style="background:#ff5f57"></span>
            <span style="background:#febc2e"></span>
            <span style="background:#28c840"></span>
          </div>
          <span class="terminal__title">agustin@portfolio:~</span>
        </div>

        <div class="terminal__body">
          <!-- cmd 1 -->
          <div class="t-line">
            <span class="t-prompt">❯</span>
            <span class="t-cmd"> whoami</span>
          </div>
          <div class="t-out t-val">agustin_monti</div>

          <!-- cmd 2 -->
          <div class="t-line">
            <span class="t-prompt">❯</span>
            <span class="t-cmd"> cat about.yaml</span>
          </div>
          <div class="t-out t-kv">
            <span class="t-key">role</span><span class="t-sep">:</span><span class="t-val">"Ing. Informática (student)"</span>
            <span class="t-key">focus</span><span class="t-sep">:</span><span class="t-val">"Linux · Infra · DevOps"</span>
            <span class="t-key">location</span><span class="t-sep">:</span><span class="t-val">"Córdoba, Argentina 🇦🇷"</span>
            <span class="t-key">languages</span><span class="t-sep">:</span><span class="t-val">["Español", "Inglés"]</span>
            <span class="t-key">goal</span><span class="t-sep">:</span><span class="t-val">"SRE / DevOps"</span>
          </div>

          <!-- cmd 3 -->
          <div class="t-line">
            <span class="t-prompt">❯</span>
            <span class="t-cmd"> docker ps</span>
          </div>
          <div class="t-out">
            <div class="t-table-head">
              <span>CONTAINER</span><span>STATUS</span>
            </div>
            <div class="t-table-row">
              <span>learning</span><span class="t-status">Up 4+ years</span>
            </div>
            <div class="t-table-row">
              <span>building</span><span class="t-status">Always running</span>
            </div>
          </div>

          <!-- cursor -->
          <div class="t-line t-line--active">
            <span class="t-prompt">❯</span>
            <span class="t-cursor"></span>
          </div>
        </div>
      </div>

      <!-- Floating glow behind terminal -->
      <div class="terminal__glow" aria-hidden="true"></div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" data-hero="scroll" aria-hidden="true">
    <span class="hero__scroll-label">scroll</span>
    <div class="hero__scroll-bar"></div>
  </div>
</section>

<style>
  .hero {
    position: relative; z-index: 1;
    min-height: 100svh;
    display: flex; flex-direction: column; justify-content: center;
    padding-top: 3rem; padding-bottom: 4rem;
  }

  .hero__cursor {
    display: inline-block;
    width: 2px; background: var(--green-500);
    animation: blink 1s step-end infinite;
    margin-left: 1px; vertical-align: middle;
    height: 0.9em;
  }

  .hero__inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
  }

  /* ── Badge ── */
  .hero__badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-mono); font-size: 0.72rem;
    color: var(--green-400);
    background: rgba(34, 197, 94, 0.07);
    border: 1px solid rgba(34, 197, 94, 0.18);
    padding: 0.35rem 0.875rem; border-radius: 999px;
    margin-bottom: 1.5rem; letter-spacing: 0.04em;
  }

  .hero__pulse {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--green-500); flex-shrink: 0;
    animation: pulse 2.2s ease-in-out infinite;
  }

  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.25} }

  /* ── Name ── */
  .hero__name {
    font-size: clamp(3.2rem, 7vw, 5.5rem);
    font-weight: 700; letter-spacing: -0.035em;
    color: var(--green-50); margin-bottom: 1rem;
  }

  .hero__name-green { color: var(--green-400); }

  /* ── Role / desc ── */
  .hero__role {
    font-family: var(--font-mono); font-size: 0.9375rem;
    color: var(--text-muted); margin-bottom: 1.25rem;
  }

  .hero__comment { color: var(--green-700); }

  .hero__desc {
    font-size: 1rem; color: var(--text-muted); line-height: 1.75;
    max-width: 44ch; margin-bottom: 2.5rem;
  }

  .hl { color: var(--green-300); font-weight: 500; }

  .hero__ctas { display: flex; gap: 0.875rem; flex-wrap: wrap; }

  /* ── Terminal ── */
  .hero__terminal-wrap { position: relative; }

  .terminal__glow {
    position: absolute; inset: -40px; z-index: -1;
    background: radial-gradient(circle at 50% 50%, rgba(34, 197, 94, 0.07), transparent 70%);
    filter: blur(20px);
  }

  .terminal {
    background: rgba(8, 18, 11, 0.75);
    border: 1px solid var(--border);
    border-radius: 0.875rem; overflow: hidden;
    backdrop-filter: blur(14px);
    box-shadow: 0 32px 80px rgba(0,0,0,0.55), 0 0 0 1px rgba(34,197,94,0.05);
  }

  .terminal__bar {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    background: rgba(4, 10, 6, 0.5);
    border-bottom: 1px solid var(--border);
  }

  .terminal__dots {
    display: flex; gap: 6px;
  }

  .terminal__dots span {
    width: 10px; height: 10px; border-radius: 50%;
  }

  .terminal__title {
    font-family: var(--font-mono); font-size: 0.72rem;
    color: var(--text-muted); margin-left: auto;
  }

  .terminal__body {
    padding: 1.25rem 1.5rem;
    display: flex; flex-direction: column; gap: 0.2rem;
    font-family: var(--font-mono); font-size: 0.8125rem;
  }

  .t-line {
    display: flex; align-items: center; gap: 0.4rem;
    margin-top: 0.6rem;
  }

  .t-prompt { color: var(--green-500); }
  .t-cmd    { color: var(--green-300); }

  .t-out {
    padding-left: 1.1rem; color: var(--text-muted); margin-bottom: 0.25rem;
  }

  .t-val { color: var(--text-muted); }

  .t-kv {
    display: grid; grid-template-columns: 5.5rem 0.75rem 1fr;
    gap: 0.18rem 0; padding-left: 1.1rem;
    align-items: start;
  }

  .t-key  { color: var(--green-600); }
  .t-sep  { color: var(--text-dim); }

  .t-table-head {
    display: flex; gap: 2.5rem;
    font-size: 0.65rem; letter-spacing: 0.1em; color: var(--text-dim);
    margin-bottom: 0.25rem;
  }

  .t-table-row { display: flex; gap: 2.5rem; color: var(--text-muted); }
  .t-status    { color: var(--green-500); }

  .t-line--active { margin-top: 0.6rem; }

  .t-cursor {
    display: inline-block; width: 8px; height: 1rem;
    background: var(--green-500);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* ── Scroll indicator ── */
  .hero__scroll {
    position: absolute; bottom: 2rem; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  }

  .hero__scroll-label {
    font-family: var(--font-mono); font-size: 0.75rem;
    color: var(--text-dim); letter-spacing: 0.18em; text-transform: uppercase;
  }

  .hero__scroll-bar {
    width: 2px; height: 4.5rem;
    background: linear-gradient(to bottom, var(--green-600), transparent);
    animation: scroll-bar 2.2s ease-in-out infinite;
  }

  @keyframes scroll-bar {
    0%   { transform: scaleY(0); transform-origin: top; }
    49%  { transform: scaleY(1); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ── Responsive ── */
  @media (max-width: 820px) {
    .hero__inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero__terminal-wrap { order: -1; }
  }

  @media (max-width: 480px) {
    .hero__name { font-size: clamp(2.75rem, 10vw, 3.5rem); }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ delay: 0.15 });
  tl
    .from('[data-hero="badge"]',    { opacity: 0, y: 16, duration: 0.55, ease: 'power3.out' })
    .from('[data-hero="name"]',     { opacity: 0, y: 28, duration: 0.65, ease: 'power3.out' }, '-=0.25')
    .from('[data-hero="role"]',     { opacity: 0, y: 18, duration: 0.5,  ease: 'power3.out' }, '-=0.4')
    .from('[data-hero="desc"]',     { opacity: 0, y: 18, duration: 0.5,  ease: 'power3.out' }, '-=0.35')
    .from('[data-hero="ctas"]',     { opacity: 0, y: 18, duration: 0.5,  ease: 'power3.out' }, '-=0.3')
    .from('[data-hero="terminal"]', { opacity: 0, x: 36, duration: 0.75, ease: 'power3.out' }, '-=0.55')
    .from('[data-hero="scroll"]',   { opacity: 0, duration: 0.4 }, '-=0.1');

  /* ── Typewriter ── */
  const phrases = [
    'Ing. Informática (estudiante)',
    'Linux & Infra Enthusiast',
    'DevOps Apprentice',
    'Self-hosting Everything',
    'SRE in the making',
  ];

  const el = document.getElementById('typewriter');
  if (el) {
    let phraseIdx = 0;
    let charIdx   = 0;
    let deleting  = false;
    let paused    = false;

    const TYPING_SPEED  = 65;
    const DELETE_SPEED  = 35;
    const PAUSE_AFTER   = 1800;
    const PAUSE_BEFORE  = 350;

    function tick() {
      if (paused) return;
      const phrase = phrases[phraseIdx];

      if (!deleting) {
        el.textContent = phrase.slice(0, charIdx + 1);
        charIdx++;
        if (charIdx === phrase.length) {
          paused = true;
          setTimeout(() => { deleting = true; paused = false; tick(); }, PAUSE_AFTER);
          return;
        }
        setTimeout(tick, TYPING_SPEED);
      } else {
        el.textContent = phrase.slice(0, charIdx - 1);
        charIdx--;
        if (charIdx === 0) {
          deleting = false;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          paused = true;
          setTimeout(() => { paused = false; tick(); }, PAUSE_BEFORE);
          return;
        }
        setTimeout(tick, DELETE_SPEED);
      }
    }

    // Start after hero animation settles
    setTimeout(tick, 1400);
  }
</script>
