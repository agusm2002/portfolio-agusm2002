<nav class="nav" aria-label="Navegación principal">
  <div class="nav__pill">
    <a href="#hero" class="nav__logo">
      <span class="nav__dim">&lt;</span>agusm<span class="nav__accent">2002</span><span class="nav__dim"> /&gt;</span>
    </a>

    <ul class="nav__links" role="list">
      <li><a href="#about"    class="nav__link">Sobre mí</a></li>
      <li><a href="#skills"   class="nav__link">Skills</a></li>
      <li><a href="#projects" class="nav__link">Proyectos</a></li>
      <li><a href="#contact"  class="nav__link">Contacto</a></li>
    </ul>

    <a
      href="https://github.com/agusm2002"
      target="_blank"
      rel="noopener noreferrer"
      class="nav__gh"
      aria-label="GitHub de Agustín Monti"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
      </svg>
      GitHub
    </a>
  </div>
</nav>

<style>
  /* ── Outer wrapper — full width, provides vertical padding & centering ── */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: center;
    padding: 0.875rem 1.5rem;
    pointer-events: none;           /* clicks pass through the empty margin area */
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Hidden state (scroll down) ── */
  .nav--hidden { transform: translateY(-140%); }

  /* ── The floating pill ── */
  .nav__pill {
    pointer-events: all;
    width: 100%; max-width: 900px;
    display: flex; align-items: center; justify-content: space-between; gap: 2rem;
    background: rgba(6, 14, 9, 0.68);
    backdrop-filter: blur(22px) saturate(160%);
    -webkit-backdrop-filter: blur(22px) saturate(160%);
    border: 1px solid rgba(34, 197, 94, 0.13);
    border-radius: 0.875rem;
    padding: 0.75rem 1.25rem;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(34, 197, 94, 0.04) inset;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .nav__pill:hover {
    border-color: rgba(34, 197, 94, 0.22);
    box-shadow: 0 4px 40px rgba(0, 0, 0, 0.4), 0 0 24px rgba(34, 197, 94, 0.05);
  }

  /* ── Logo ── */
  .nav__logo {
    font-family: var(--font-mono);
    font-size: 0.875rem; font-weight: 500;
    color: var(--text); white-space: nowrap;
    transition: color 0.2s;
  }

  .nav__logo:hover { color: var(--green-300); }
  .nav__dim    { color: var(--text-dim); }
  .nav__accent { color: var(--green-400); }

  /* ── Links ── */
  .nav__links {
    display: flex; align-items: center; gap: 1.5rem; list-style: none;
  }

  .nav__link {
    font-family: var(--font-mono);
    font-size: 0.875rem; color: var(--text-muted); font-weight: 400;
    transition: color 0.18s; position: relative; padding-block: 0.1rem;
  }

  .nav__link::after {
    content: ''; position: absolute; bottom: -1px; left: 0;
    width: 0; height: 1px; background: var(--green-500);
    transition: width 0.2s ease;
  }

  .nav__link:hover            { color: var(--green-300); }
  .nav__link:hover::after     { width: 100%; }

  /* ── GitHub button ── */
  .nav__gh {
    display: inline-flex; align-items: center; gap: 0.45rem;
    font-family: var(--font-display); font-size: 0.78rem; font-weight: 500;
    color: var(--green-400);
    background: rgba(34, 197, 94, 0.07);
    border: 1px solid rgba(34, 197, 94, 0.18);
    padding: 0.35rem 0.875rem; border-radius: 0.5rem;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    white-space: nowrap;
  }

  .nav__gh:hover {
    background: rgba(34, 197, 94, 0.13);
    border-color: rgba(34, 197, 94, 0.32);
    color: var(--green-300);
  }

  @media (max-width: 680px) {
    .nav__links { display: none; }
    .nav__pill  { padding: 0.5rem 1rem; }
  }
  @media (max-width: 420px) {
    .nav__gh  { display: none; }
  }
</style>
