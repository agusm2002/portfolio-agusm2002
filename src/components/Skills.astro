---
interface Category {
  svg: string;
  label: string;
  skills: string[];
}

// All SVGs are Tabler Icons (stroke-based, 24×24, stroke-width 1.75)
const categories: Category[] = [
  {
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
    label: 'Sistemas Operativos',
    skills: ['Linux', 'Debian', 'Ubuntu', 'Bash Shell'],
  },
  {
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="5" rx="1"/><rect x="2" y="10" width="20" height="5" rx="1"/><rect x="2" y="17" width="20" height="5" rx="1"/><circle cx="6" cy="5.5" r=".75" fill="currentColor" stroke="none"/><circle cx="6" cy="12.5" r=".75" fill="currentColor" stroke="none"/><circle cx="6" cy="19.5" r=".75" fill="currentColor" stroke="none"/></svg>`,
    label: 'Infraestructura & DevOps',
    skills: ['Docker', 'Ansible', 'CI/CD', 'GitHub Actions'],
  },
  {
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="2" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="16" y="16" width="6" height="6" rx="1"/><path d="M12 8v4M6.5 18l5.5-6M17.5 18l-5.5-6"/></svg>`,
    label: 'Redes & Seguridad',
    skills: ['SSH', 'VPN', 'TCP/IP', 'Firewall', 'Hardening'],
  },
  {
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="7 8 3 12 7 16"/><polyline points="17 8 21 12 17 16"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
    label: 'Scripting & Programación',
    skills: ['Python', 'Bash', 'Shell Scripting', 'YAML'],
  },
  {
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v6c0 1.657 3.582 3 8 3s8-1.343 8-3V6"/><path d="M4 12v6c0 1.657 3.582 3 8 3s8-1.343 8-3v-6"/></svg>`,
    label: 'Bases de Datos',
    skills: ['PostgreSQL', 'MySQL', 'SQL'],
  },
  {
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="18" r="2"/><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><path d="M6 8v8"/><path d="M18 8a8 8 0 01-8 8H9"/></svg>`,
    label: 'Herramientas & VCS',
    skills: ['Git', 'GitHub', 'VS Code'],
  },
];
---

<section id="skills" class="section">
  <div class="container">
    <p class="section-label reveal">Stack Técnico</p>
    <h2 class="section-title reveal">Herramientas <span class="title-amp">&</span> tecnologías</h2>
    <p class="skills__sub reveal">Lo que uso, estudio y con lo que construyo.</p>

    <div class="skills__grid reveal-group">
      {categories.map((cat) => (
        <div class="skill-card reveal-item">
          <div class="skill-card__head">
            <span class="skill-card__icon">
              <Fragment set:html={cat.svg} />
            </span>
            <h3 class="skill-card__title">{cat.label}</h3>
          </div>
          <div class="skill-card__pills">
            {cat.skills.map((s) => <span class="spill">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills__sub {
    color: var(--text-muted); font-size: 0.9375rem;
    margin-bottom: 3rem; margin-top: 0.5rem;
  }

  .title-amp { color: var(--green-500); }

  .skills__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 0.875rem;
    overflow: hidden;
  }

  .skill-card {
    background: var(--bg); padding: 1.625rem;
    transition: background 0.22s;
    cursor: default;
  }

  .skill-card:hover { background: var(--surface); }

  .skill-card__head {
    display: flex; align-items: center; gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .skill-card__icon {
    display: flex; align-items: center; justify-content: center;
    width: 2.25rem; height: 2.25rem; flex-shrink: 0;
    border-radius: 0.5rem;
    background: rgba(34, 197, 94, 0.07);
    border: 1px solid rgba(34, 197, 94, 0.14);
    color: var(--green-500);
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .skill-card:hover .skill-card__icon {
    background: rgba(34, 197, 94, 0.12);
    border-color: rgba(34, 197, 94, 0.26);
    color: var(--green-400);
  }

  .skill-card__title {
    font-family: var(--font-display);
    font-size: 0.8125rem; font-weight: 600;
    color: var(--text); letter-spacing: 0.01em;
  }

  /* ── Pills ── */
  .skill-card__pills { display: flex; flex-wrap: wrap; gap: 0.375rem; }

  .spill {
    display: inline-flex; align-items: center;
    font-family: var(--font-mono); font-size: 0.73rem; font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid rgba(34, 197, 94, 0.1);
    padding: 0.275rem 0.65rem;
    border-radius: 0.3rem;
    transition: color 0.15s, border-color 0.15s, background 0.15s, box-shadow 0.15s;
    position: relative;
  }

  .spill::before {
    content: '›';
    color: var(--green-700);
    margin-right: 0.3rem;
    font-size: 0.9rem; line-height: 1;
    transition: color 0.15s;
  }

  .skill-card:hover .spill:hover {
    color: var(--green-300);
    border-color: rgba(34, 197, 94, 0.3);
    background: rgba(34, 197, 94, 0.06);
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.07);
  }

  .skill-card:hover .spill:hover::before { color: var(--green-500); }

  @media (max-width: 900px) { .skills__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .skills__grid { grid-template-columns: 1fr; } }
</style>
